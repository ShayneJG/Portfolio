---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  pageType?: "default" | "home" | "about" | "work" | "writing" | "contact";
}

const { title, description, pageType = "default" } = Astro.props;
const fullTitle =
  pageType === "home" ? title : `${title} — Shayne Geilman`;
const desc =
  description ??
  "Engineer working in production data and LLM systems. Background in research editing and philosophy. Based in Perth.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={desc} />
    <title>{fullTitle}</title>
    <link rel="canonical" href={Astro.url.toString()} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <Header pageType={pageType} />
    <main class="page">
      <slot />
    </main>
    <Footer />
  </body>
</html>
