---
import Layout from "../layouts/Layout.astro";
import { withBase } from "../lib/url";
import { getCollection } from "astro:content";

const projects = await getCollection("sideProjects");
const work = await getCollection("work");

const featured =
  projects.find((p) => p.data.featured) ??
  projects.sort((a, b) => a.data.order - b.data.order)[0];
---

<Layout title="Shayne Geilman" pageType="home">
  <section class="hero content">
    <h1 class="display">Software · Philosophy · Research</h1>
    <p class="tag hero-dek">
      Engineer in production data and LLM systems. Trained in philosophy,
      former research editor.
    </p>
  </section>

  <hr class="rule" />

  <section class="content">
    <span class="label">Featured</span>
    {
      featured ? (
        <div class="featured">
          <h2>
            <a href={withBase(`/side-projects/${featured.id}`)}>
              {featured.data.title}
            </a>
          </h2>
          <p class="featured-sub">{featured.data.subtitle}</p>
          <span class="meta">
            {featured.data.stack.join(" · ")} · {featured.data.date}
          </span>
        </div>
      ) : (
        <p class="placeholder">
          The featured case study will live here once the first case study is
          written.
        </p>
      )
    }
  </section>

  <hr class="rule" />

  <section class="content split">
    <div>
      <span class="label">Work</span>
      <p>
        Paid roles and the things I shipped in them.{" "}
        <a href={withBase("/work")}>All work →</a>
      </p>
      {work.length === 0 && (
        <p class="placeholder">Case studies for paid roles are in progress.</p>
      )}
    </div>
    <div>
      <span class="label">Side projects</span>
      <p>
        Personal builds, tools, and experiments.{" "}
        <a href={withBase("/side-projects")}>All side projects →</a>
      </p>
    </div>
  </section>

  <hr class="rule" />

  <section class="about-writing">
    <div class="content">
      <span class="label">About</span>
      <p class="placeholder">
        A short teaser of the polymath narrative will live here.{" "}
        <a href={withBase("/about")}>More on /about →</a>
      </p>
    </div>
    <div class="content">
      <span class="label">Recent writing</span>
      <p class="placeholder">
        The two most recent posts will live here.{" "}
        <a href={withBase("/writing")}>All writing →</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  /* H1 uses the .display class: same treatment as subpage page
     titles (About, Work, Writing). Three-noun title-card form keeps
     the home H1 in the same family as the others rather than
     drifting into hero-paragraph territory. */

  /* Dek sits under the H1: explains what the three nouns mean and
     gives a hiring manager the positioning in one line. */
  .hero-dek {
    margin-top: var(--space-l);
  }

  .placeholder {
    color: var(--ink-muted);
    font-style: italic;
    font-size: 16px;
    max-width: var(--content-width);
  }
  .featured {
    max-width: var(--content-width);
  }
  .featured h2 {
    margin-top: var(--space-s);
    margin-bottom: var(--space-xs);
  }
  .featured h2 a {
    color: var(--ink);
    text-decoration: none;
  }
  .featured h2 a:hover {
    color: var(--accent);
  }
  .featured-sub {
    font-size: 17px;
    color: var(--ink-soft);
    margin-bottom: var(--space-xs);
  }
  .split {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }
  @media (min-width: 768px) {
    .split {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
  }
  .about-writing {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    padding: var(--space-xl) 0;
  }
  @media (min-width: 768px) {
    .about-writing {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
  }
</style>
