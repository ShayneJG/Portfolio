---
import Layout from "../layouts/Layout.astro";
import { withBase } from "../lib/url";
---

<Layout title="Shayne Geilman" pageType="home">
  <section class="hero content">
    <h1 class="hero-lead">
      Engineer in production data and LLM systems —<br />
      background in research editing and philosophy.
    </h1>
  </section>

  <hr class="rule" />

  <section class="content">
    <span class="label">Featured</span>
    <p class="placeholder">
      The featured case study will live here once the first case study is
      written.
    </p>
  </section>

  <hr class="rule" />

  <section class="content">
    <span class="label">More work</span>
    <p class="placeholder">
      The project list will live here once the case studies and personal
      projects are added to the <code>work</code> content collection.
    </p>
  </section>

  <hr class="rule" />

  <section class="about-writing">
    <div class="content">
      <span class="label">About</span>
      <p class="placeholder">
        A short teaser of the polymath narrative will live here.{" "}
        <a href={withBase("/about")}>More on /about →</a>
      </p>
    </div>
    <div class="content">
      <span class="label">Recent writing</span>
      <p class="placeholder">
        The two most recent posts will live here.{" "}
        <a href={withBase("/writing")}>All writing →</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
  }

  /* The home page hero is the positioning sentence — set in display
     type. Replaces the previous "Shayne Geilman" H1, since the
     wordmark in the header already answers "who is this person?". */
  .hero-lead {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 32px;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--ink);
    max-width: var(--content-width);
  }
  @media (min-width: 768px) {
    .hero-lead {
      font-size: 44px;
      line-height: 1.1;
    }
  }

  .placeholder {
    color: var(--ink-muted);
    font-style: italic;
    font-size: 16px;
    max-width: var(--content-width);
  }
  .about-writing {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    padding: var(--space-xl) 0;
  }
  @media (min-width: 768px) {
    .about-writing {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
  }
</style>
