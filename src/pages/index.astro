---
import Layout from "../layouts/Layout.astro";
import { withBase } from "../lib/url";
---

<Layout title="Shayne Geilman" pageType="home">
  <section class="hero content">
    <h1 class="display">Software · Philosophy · Research</h1>
    <p class="tag hero-dek">
      Engineer in production data and LLM systems, with a background in
      philosophy and research editing.
    </p>
  </section>

  <hr class="rule" />

  <section class="content">
    <span class="label">Featured</span>
    <p class="placeholder">
      The featured case study will live here once the first case study is
      written.
    </p>
  </section>

  <hr class="rule" />

  <section class="content">
    <span class="label">More work</span>
    <p class="placeholder">
      The project list will live here once the case studies and personal
      projects are added to the <code>work</code> content collection.
    </p>
  </section>

  <hr class="rule" />

  <section class="about-writing">
    <div class="content">
      <span class="label">About</span>
      <p class="placeholder">
        A short teaser of the polymath narrative will live here.{" "}
        <a href={withBase("/about")}>More on /about →</a>
      </p>
    </div>
    <div class="content">
      <span class="label">Recent writing</span>
      <p class="placeholder">
        The two most recent posts will live here.{" "}
        <a href={withBase("/writing")}>All writing →</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  /* H1 uses the .display class — same treatment as subpage page
     titles (About, Work, Writing). Three-noun title-card form keeps
     the home H1 in the same family as the others rather than
     drifting into hero-paragraph territory. */

  /* Dek sits under the H1 — explains what the three nouns mean and
     gives a hiring manager the positioning in one line. */
  .hero-dek {
    margin-top: var(--space-l);
  }

  .placeholder {
    color: var(--ink-muted);
    font-style: italic;
    font-size: 16px;
    max-width: var(--content-width);
  }
  .about-writing {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    padding: var(--space-xl) 0;
  }
  @media (min-width: 768px) {
    .about-writing {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
  }
</style>
