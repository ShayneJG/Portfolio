---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { withBase } from "../../lib/url";

export async function getStaticPaths() {
  const entries = await getCollection("sideProjects");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const { repo, liveUrl, status, stack, date } = entry.data;
const links = [
  liveUrl ? { label: "Live", href: liveUrl } : null,
  repo ? { label: "Source", href: repo } : null,
].filter((l): l is { label: string; href: string } => l !== null);
---

<Layout
  title={entry.data.title}
  description={entry.data.subtitle}
  pageType="side-projects"
>
  <article class="content case-study">
    <header class="case-header">
      <h1 class="display">{entry.data.title}</h1>
      <p class="tag">{entry.data.subtitle}</p>
      <p class="meta case-meta">
        {stack.join(" · ")} · {date}{status ? ` · ${status}` : ""}
      </p>
      {links.length > 0 && (
        <p class="case-links">
          {links.map((link, i) => (
            <>
              {i > 0 && <span class="sep"> · </span>}
              <a href={link.href} target="_blank" rel="noopener noreferrer">
                {link.label} ↗
              </a>
            </>
          ))}
        </p>
      )}
    </header>

    <div class="case-body prose">
      <Content />
    </div>

    <footer class="case-footer">
      <a href={withBase("/side-projects")}>← All side projects</a>
    </footer>
  </article>
</Layout>

<style>
  .case-study {
    padding: var(--space-2xl) 0;
  }
  .case-header {
    margin-bottom: var(--space-2xl);
  }
  .case-header .display {
    margin-bottom: var(--space-m);
  }
  .case-header .tag {
    margin-bottom: var(--space-l);
  }
  .case-meta {
    color: var(--ink-muted);
  }
  .case-links {
    margin-top: var(--space-s);
    font-family: var(--font-sans);
    font-size: 13px;
  }
  .case-links a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
  }
  .case-links a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .sep {
    color: var(--ink-muted);
  }
  .case-footer {
    margin-top: var(--space-3xl);
    padding-top: var(--space-l);
    border-top: 1px solid var(--rule);
  }
  .case-footer a {
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--ink-soft);
  }
  .case-footer a:hover {
    color: var(--accent);
  }

  .prose :global(h2) {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-m);
  }
  .prose :global(h3) {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-s);
  }
  .prose :global(p) {
    margin-bottom: var(--space-m);
    max-width: var(--content-width);
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-m);
    padding-left: var(--space-l);
    max-width: var(--content-width);
  }
  .prose :global(li) {
    margin-bottom: var(--space-xs);
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
  }
  .prose :global(img) {
    margin: var(--space-l) 0;
    border-radius: 4px;
  }
  .prose :global(figure) {
    margin: var(--space-l) 0;
  }
  .prose :global(figcaption) {
    font-size: 14px;
    color: var(--ink-muted);
    margin-top: var(--space-xs);
    font-family: var(--font-sans);
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: var(--space-l) 0;
    max-width: var(--content-width);
  }
</style>
